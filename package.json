{
  "name": "supply-chain-mcp-server",
  "version": "0.1.0",
  "description": "Software supply chain security MCP server — vulnerability scanning, package analysis, provenance verification, typosquatting detection, dependency intelligence across npm, PyPI, crates.io, Go, and more",
  "type": "module",
  "bin": {
    "supply-chain-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "supply-chain",
    "supply-chain-security",
    "software-composition-analysis",
    "sca",
    "vulnerability",
    "dependency",
    "osv",
    "ghsa",
    "cve",
    "nvd",
    "npm-audit",
    "pypi",
    "crates-io",
    "golang",
    "sigstore",
    "rekor",
    "provenance",
    "scorecard",
    "openssf",
    "typosquatting",
    "sbom",
    "osint",
    "cybersecurity",
    "security",
    "infosec",
    "ai",
    "ai-agent",
    "claude",
    "llm"
  ],
  "author": "Orhan Yildirim <contact@orhanyildirim.us> (https://orhanyildirim.us)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badchars/supply-chain-mcp-server.git"
  },
  "homepage": "https://www.npmjs.com/package/supply-chain-mcp-server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.2"
  }
}
